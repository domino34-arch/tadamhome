{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/",          "destination": "/index.html" },
    { "source": "/login",     "destination": "/login.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" }
  ],
  "routes": [
    { "src": "/edito/(.*)", "dest": "/edito.html" }
  ]
}
